    "dependencies": {
        "@prisma/client": "^5.20.0",
        "express": "^4.21.0",
        "dotenv": "^16.4.5"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^22.0.0",
        "prisma": "^5.20.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.6.0"
    }
}