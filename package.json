{
    "name": "clinic-api-assignment",
    "version": "1.0.0",
    "description": "Clinic Appointment API - Starter Project",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
